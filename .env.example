# Supabase Configuration
VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Supabase Edge Functions Environment Variables
# Add these to your Supabase project's edge function secrets
# Dashboard → Project Settings → Edge Functions → Manage secrets

# Core (Required)
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Email Service (Required for job applications)
# RESEND_API_KEY="re_your_resend_api_key"

# AI Features (Optional)
# ANTHROPIC_API_KEY="your-anthropic-api-key"

# Job Scraping (Optional)
# FIRECRAWL_API_KEY="your-firecrawl-api-key"

# SEO & Indexing (Optional)
# Google Indexing API service account credentials (set as secrets; never commit real values)
GOOGLE_INDEXING_CLIENT_EMAIL=
# Keep this private key secret. In Vercel/Lovable, paste with escaped \n or preserve multiline formatting if supported.
# The app converts "\\n" back to real newlines in code.
GOOGLE_INDEXING_PRIVATE_KEY=
GOOGLE_INDEXING_PROJECT_ID=
GOOGLE_INDEXING_TOKEN_URI="https://oauth2.googleapis.com/token"
JOBBYIST_BASE_URL="https://za.jobbyist.africa"
# Never commit your service-account JSON file to the repository.

# Payment Processing (Required for Pro features)
# PayFast (Recommended for South Africa)
# PAYFAST_MERCHANT_ID="your-merchant-id"
# PAYFAST_MERCHANT_KEY="your-merchant-key"
# PAYFAST_PASSPHRASE="your-passphrase"

# Stripe (International fallback)
# STRIPE_SECRET_KEY="sk_your_stripe_secret_key"
# STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# 30-Day Job Sprint Page (Optional front-end CTA config)
VITE_BUSINESS_WHATSAPP_NUMBER="27680000000"
VITE_JOB_SPRINT_CHECKOUT_LITE="https://your-checkout-provider.com/sprint-lite"
VITE_JOB_SPRINT_CHECKOUT_GUIDED="https://your-checkout-provider.com/guided-sprint"
VITE_JOB_SPRINT_CHECKOUT_PREMIUM="https://your-checkout-provider.com/premium-sprint"
